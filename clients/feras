<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Feras NFC Card</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: linear-gradient(135deg, #0f172a, #111827);
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 30px;
    border-radius: 25px;
    width: 340px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.1);
}

img {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #38bdf8;
    margin-bottom: 15px;
}

h1 {
    margin: 10px 0;
    font-size: 22px;
}

p {
    color: #cbd5e1;
    margin-bottom: 20px;
}

.btn {
    display: block;
    margin: 10px 0;
    padding: 12px;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    font-weight: bold;
    transition: 0.3s;
}

.btn:hover {
    transform: scale(1.05);
}

.whatsapp { background: #22c55e; }
.call { background: #f59e0b; }
.email { background: #3b82f6; }
.location { background: #a855f7; }
</style>

</head>

<body>

<div class="card">

    <img src="https://via.placeholder.com/110" alt="profile">

    <h1>Feras</h1>
    <p>Digital NFC Card</p>

    <a class="btn whatsapp" href="https://wa.me/000000000">💬 WhatsApp</a>
    <a class="btn call" href="tel:000000000">📞 Call</a>
    <a class="btn email" href="mailto:test@email.com">📧 Email</a>
    <a class="btn location" href="#">📍 Location</a>

</div>

</body>
</html>
